{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SerialPlotster",
  "version": "0.2.0",
  "identifier": "com.todbot.serial-plotster",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SerialPlotster",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["Credits.html"],
    "publisher": "Tod Kurt",
    "copyright": "© 2025 Tod Kurt",
    "homepage": "https://github.com/todbot/SerialPlotster",
    "shortDescription": "A cross-platform serial plotter for Arduino and other devices.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
